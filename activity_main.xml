<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#EFEBE9">

    <include layout="@layout/toolbar"/>
    <TextView
        android:layout_width="260dp"
        android:layout_height="40dp"
        android:textSize="25sp"
        android:text="Datos de registro "
        android:fontFamily="@font/cinzel"
        android:textColor="#3E2723"/>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- MARCA -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="País"
                    android:fontFamily="@font/italika"
                    android:textColor="#3E2723"/>

                <EditText
                    android:id="@+id/etPais"
                    android:fontFamily="@font/cinzel"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Marca"
                    android:fontFamily="@font/italika"
                    android:textColor="#3E2723"/>

                <EditText
                    android:id="@+id/etMarca"
                    android:fontFamily="@font/cinzel"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"/>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:fontFamily="@font/italika"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Precio"
                    android:textColor="#3E2723"/>

                <EditText
                    android:fontFamily="@font/cinzel"
                    android:id="@+id/etPrecio"
                    android:inputType="numberDecimal"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:fontFamily="@font/italika"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Teléfono"
                    android:textColor="#3E2723"/>

                <EditText
                    android:fontFamily="@font/cinzel"
                    android:id="@+id/etTelefono"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="phone"/>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:fontFamily="@font/italika"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Empresa"
                    android:textColor="#3E2723"/>

                <EditText
                    android:fontFamily="@font/cinzel"
                    android:id="@+id/etEmpresa"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"/>
            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="260dp"
            android:textSize="25sp"
            android:layout_height="40dp"
            android:text="Datos del Café "
            android:fontFamily="@font/cinzel"
            android:textColor="#3E2723"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:fontFamily="@font/cinzel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grano"
                    android:textColor="#3E2723"/>

                <Spinner
                    android:id="@+id/spgrano"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:fontFamily="@font/cinzel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tostado"
                    android:textColor="#3E2723"/>

                <Spinner
                    android:id="@+id/sptostado"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:fontFamily="@font/cinzel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Intensidad"
                    android:textColor="#3E2723"/>

                <Spinner
                    android:id="@+id/spinten"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="260dp"
            android:textSize="25sp"
            android:layout_height="40dp"
            android:text="Datos de Mercado "
            android:fontFamily="@font/cinzel"
            android:textColor="#3E2723"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- MARCA -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:fontFamily="@font/cinzel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Presentacion"
                        android:textColor="#3E2723"/>

                    <Spinner
                        android:id="@+id/sppres"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:fontFamily="@font/cinzel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Peso"
                        android:textColor="#3E2723"/>

                    <Spinner
                        android:id="@+id/sppeso"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"/>
                </LinearLayout>

            </LinearLayout>

        <Button
            android:fontFamily="@font/cinzel"
            android:id="@+id/btnRegistrar"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:text="Registrar café"
            android:backgroundTint="#4E342E"
            android:textColor="#EFEBE9"/>

    </LinearLayout>

    </LinearLayout>

</LinearLayout>
